+TEST_CASE("squiggly_purge: placement") {
+    Params p;
+    const Rect bed { 0, 0, 250, 220 }; // CoreOne-like
+
+    SECTION("defaults to the front-left corner") {
+        const auto s = compute_placement(p, bed, std::nullopt, std::nullopt, std::nullopt);
+        REQUIRE(s.has_value());
+        REQUIRE(s->x == Approx(5.f));
+        REQUIRE(s->y == Approx(3.5f));
+    }
+
+    SECTION("Y-direction line swaps the frame") {
+        p.along_y = true;
+        const auto s = compute_placement(p, bed, std::nullopt, std::nullopt, std::nullopt);
+        REQUIRE(s.has_value());
+        REQUIRE(s->x == Approx(3.5f));
+        REQUIRE(s->y == Approx(5.f));
+    }
+
+    SECTION("adaptive slides the line toward the print area") {
+        const Rect area { 150, 80, 200, 120 };
+        const auto s = compute_placement(p, bed, area, std::nullopt, std::nullopt);
+        REQUIRE(s.has_value());
+        REQUIRE(s->x == Approx(140.f)); // clamped into [150-10, 200+10]
+        REQUIRE(s->y == Approx(3.5f)); // cross coordinate untouched
+    }
+
+    SECTION("adaptive near the far bed edge is pulled back onto the bed") {
+        const Rect area { 230, 100, 248, 120 };
+        const auto s = compute_placement(p, bed, area, std::nullopt, std::nullopt);
+        REQUIRE(s.has_value());
+        // adaptive wants 220; envelope clamp allows at most 250 - 50 = 200
+        REQUIRE(s->x == Approx(200.f));
+    }
+
+    SECTION("print area already near the default keeps the default") {
+        const Rect area { 10, 10, 60, 60 };
+        const auto s = compute_placement(p, bed, area, std::nullopt, std::nullopt);
+        REQUIRE(s.has_value());
+        REQUIRE(s->x == Approx(5.f)); // already within [0, 70]
+    }
+
+    SECTION("adaptive off ignores the print area") {
+        p.adaptive = false;
+        const Rect area { 150, 80, 200, 120 };
+        const auto s = compute_placement(p, bed, area, std::nullopt, std::nullopt);
+        REQUIRE(s.has_value());
+        REQUIRE(s->x == Approx(5.f));
+    }
+
+    SECTION("cross-coordinate override is clamped to keep the amplitude on the bed") {
+        const auto s = compute_placement(p, bed, std::nullopt, std::nullopt, 218.f);
+        REQUIRE(s.has_value());
+        REQUIRE(s->y == Approx(215.f)); // 220 - amplitude
+    }
+
+    SECTION("line longer than the bed does not fit") {
+        const Rect narrow_bed { 0, 0, 40, 220 };
+        const auto s = compute_placement(p, narrow_bed, std::nullopt, std::nullopt, std::nullopt);
+        REQUIRE_FALSE(s.has_value());
+        REQUIRE(s.error() == Error::does_not_fit);
+    }
+
+    SECTION("amplitude taller than the bed does not fit") {
+        p.amplitude = 300.f;
+        const auto s = compute_placement(p, bed, std::nullopt, std::nullopt, std::nullopt);
+        REQUIRE_FALSE(s.has_value());
+        REQUIRE(s.error() == Error::does_not_fit);
+    }
+}
