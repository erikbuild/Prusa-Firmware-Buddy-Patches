+/// @file
+// ABOUTME: Host unit tests for the squiggly purge pure geometry module.
+// ABOUTME: Reference values are analytic (default params, 1.75 mm filament).
+#include <feature/squiggly_purge/squiggly_purge.hpp>
+
+#include <catch2/catch_approx.hpp>
+#include <catch2/catch_test_macros.hpp>
+#include <cmath>
+
+using Catch::Approx;
+using namespace squiggly_purge;
+
+TEST_CASE("squiggly_purge: path generation") {
+    Params p;
+
+    SECTION("segment count is periods x steps") {
+        REQUIRE(segment_count(p) == 160);
+    }
+
+    SECTION("path starts at origin of the line frame") {
+        REQUIRE(path_point(p, 0).along == Approx(0.f));
+        REQUIRE(path_point(p, 0).across == Approx(0.f));
+    }
+
+    SECTION("crest of the first period reaches the amplitude") {
+        // half a period in: cos(pi) = -1 -> across = amplitude
+        const auto crest = path_point(p, p.steps_per_period / 2);
+        REQUIRE(crest.along == Approx(p.wavelength / 2));
+        REQUIRE(crest.across == Approx(p.amplitude));
+    }
+
+    SECTION("period boundary returns to zero offset") {
+        const auto trough = path_point(p, p.steps_per_period);
+        REQUIRE(trough.along == Approx(p.wavelength));
+        REQUIRE(trough.across == Approx(0.f).margin(1e-5));
+    }
+
+    SECTION("path length matches the analytic reference") {
+        REQUIRE(path_length(p) == Approx(114.6837f).epsilon(0.001));
+    }
+
+    SECTION("path length exceeds the straight-line length") {
+        REQUIRE(path_length(p) > float(p.periods) * p.wavelength);
+    }
+}
+
+TEST_CASE("squiggly_purge: extrusion geometry") {
+    Params p;
+
+    SECTION("default parameters match the analytic reference") {
+        const auto g = compute_geometry(p);
+        REQUIRE(g.has_value());
+        REQUIRE(g->line_width == Approx(3.49553f).epsilon(0.001));
+        REQUIRE(g->feedrate == Approx(4.76799f).epsilon(0.001));
+        REQUIRE(g->purge_length == Approx(100.f));
+        REQUIRE_FALSE(g->capped);
+    }
+
+    SECTION("cross-section limit shortens the purge") {
+        p.max_cross_section = 1.5f;
+        const auto g = compute_geometry(p);
+        REQUIRE(g.has_value());
+        REQUIRE(g->capped);
+        // 0.98 * B * path_length / filament_area
+        REQUIRE(g->purge_length == Approx(70.0895f).epsilon(0.001));
+        // capped width = 0.98 * B / H
+        REQUIRE(g->line_width == Approx(2.45f).epsilon(0.001));
+    }
+
+    SECTION("Klipper's default cross-section cap makes the default line too thin") {
+        // documents why B defaults to 5 (KAMP) instead of Klipper's 4*nozzle_d^2
+        p.max_cross_section = 0.64f;
+        const auto g = compute_geometry(p);
+        REQUIRE_FALSE(g.has_value());
+        REQUIRE(g.error() == Error::line_too_thin);
+    }
+
+    SECTION("short purge on a long path is too thin to stick") {
+        p.purge_length = 20.f;
+        const auto g = compute_geometry(p);
+        REQUIRE_FALSE(g.has_value());
+        REQUIRE(g.error() == Error::line_too_thin);
+    }
+
+    SECTION("degenerate parameters are rejected") {
+        SECTION("zero periods") { p.periods = 0; }
+        SECTION("zero steps") { p.steps_per_period = 0; }
+        SECTION("zero wavelength") { p.wavelength = 0; }
+        SECTION("zero line height") { p.line_height = 0; }
+        SECTION("zero purge length") { p.purge_length = 0; }
+        SECTION("zero flowrate") { p.flowrate = 0; }
+        SECTION("zero cross-section limit") { p.max_cross_section = 0; }
+        SECTION("negative amplitude") { p.amplitude = -1; }
+        SECTION("negative margin") { p.margin = -1; }
+        const auto g = compute_geometry(p);
+        REQUIRE_FALSE(g.has_value());
+        REQUIRE(g.error() == Error::degenerate_params);
+    }
+}
