+// Integration: the full parameter -> move-plan pipeline over a tiny line whose
+// numbers are exactly computable by hand. 2 periods x 2 steps of a 5 mm
+// wavelength: 4 equal segments of hypot(2.5, 5) = 5.59017 mm, path 22.36068 mm.
+// The natural width (17.93 mm) exceeds B=5, so the purge is capped:
+// purge = 0.98 * 5 * 22.36068 / 2.405282 = 45.5508 mm, width = 0.98*5/0.6 = 8.16667 mm.
+TEST_CASE("squiggly_purge: full move plan for a tiny line") {
+    Params p;
+    p.periods = 2;
+    p.steps_per_period = 2;
+    const Rect bed { 0, 0, 250, 220 };
+
+    const auto geometry = compute_geometry(p);
+    REQUIRE(geometry.has_value());
+    REQUIRE(geometry->capped);
+    REQUIRE(geometry->purge_length == Approx(45.5508f).epsilon(0.001));
+    REQUIRE(geometry->line_width == Approx(8.16667f).epsilon(0.001));
+    REQUIRE(geometry->feedrate == Approx(2.04082f).epsilon(0.001));
+
+    const auto start = compute_placement(p, bed, std::nullopt, std::nullopt, std::nullopt);
+    REQUIRE(start.has_value());
+
+    // Assemble absolute vertices and cumulative extrusion the way the handler does
+    const float length = path_length(p);
+    struct Move {
+        float x, y, e;
+    };
+    Move moves[4];
+    float e = 0;
+    PathPoint prev = path_point(p, 0);
+    for (int i = 1; i <= segment_count(p); i++) {
+        const PathPoint pt = path_point(p, i);
+        e += std::hypot(pt.along - prev.along, pt.across - prev.across) / length * geometry->purge_length;
+        moves[i - 1] = { start->x + pt.along, start->y + pt.across, e };
+        prev = pt;
+    }
+
+    const Move expected[4] = {
+        { 7.5f, 8.5f, 11.3877f },
+        { 10.0f, 3.5f, 22.7754f },
+        { 12.5f, 8.5f, 34.1631f },
+        { 15.0f, 3.5f, 45.5508f },
+    };
+    for (int i = 0; i < 4; i++) {
+        CAPTURE(i);
+        REQUIRE(moves[i].x == Approx(expected[i].x).epsilon(0.001));
+        REQUIRE(moves[i].y == Approx(expected[i].y).margin(0.01));
+        REQUIRE(moves[i].e == Approx(expected[i].e).epsilon(0.001));
+    }
+}
