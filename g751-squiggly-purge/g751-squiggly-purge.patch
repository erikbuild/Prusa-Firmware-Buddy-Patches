+/// @file
+// ABOUTME: G751 handler that draws a squiggly (cosine wave) purge line.
+// ABOUTME: Port of the Klipper community "squiggly purge" macro.
+
+#include "PrusaGcodeSuite.hpp"
+
+#include <cmath>
+#include <core/serial.h>
+#include <feature/print_area.h>
+#include <feature/squiggly_purge/squiggly_purge.hpp>
+#include <gcode/gcode_parser.hpp>
+#include <limits>
+#include <module/motion.h>
+#include <module/planner.h>
+#include <module/temperature.h>
+
+namespace {
+constexpr float travel_feedrate = 300.f; ///< mm/s
+constexpr float z_feedrate = 10.f; ///< mm/s
+constexpr float pressurize_feedrate = 5.f; ///< mm/s
+constexpr float retract_feedrate = 35.f; ///< mm/s
+constexpr float safe_z = 5.f; ///< minimum Z for the travel to the line start, mm
+constexpr float squish = 0.8f; ///< fraction of line height used as the first-touch Z
+constexpr float retract = 0.2f; ///< retraction after the line, mm
+constexpr float end_hop = 3.f; ///< Z hop after the line, mm
+constexpr float sidestep = 5.f; ///< XY move away from the finished line, mm
+
+void report_error(squiggly_purge::Error error) {
+    switch (error) {
+    case squiggly_purge::Error::degenerate_params:
+        SERIAL_ERROR_MSG("G751: invalid parameters");
+        break;
+    case squiggly_purge::Error::line_too_thin:
+        SERIAL_ERROR_MSG("G751: line too thin to stick; increase L or decrease P/W/A");
+        break;
+    case squiggly_purge::Error::does_not_fit:
+        SERIAL_ERROR_MSG("G751: line does not fit on the bed");
+        break;
+    }
+}
+} // namespace
+
+/** \addtogroup G-Codes
+ * @{
+ */
+
+/**
+ * ### G751: Squiggly purge line
+ *
+ * Draws a cosine-wave prime line and purges the given length of filament along
+ * it. Line width and feedrate are derived from the purge length and volumetric
+ * flowrate. With adaptive placement (default), the line slides along its
+ * direction toward the print area previously set by `M555`.
+ *
+ * #### Usage
+ *
+ *     G751 [ L ] [ Q ] [ A ] [ W ] [ P ] [ S ] [ H ] [ U ] [ D ] [ X ] [ Y ] [ C ] [ M ] [ B ]
+ *
+ * #### Parameters
+ *
+ * - `L` - Purge length [mm of filament] (default 100)
+ * - `Q` - Volumetric flowrate [mm^3/s] (default 10)
+ * - `A` - Squiggle amplitude [mm] (default 5)
+ * - `W` - Wavelength of one period [mm] (default 5)
+ * - `P` - Number of periods (default 10)
+ * - `S` - Line segments per period (default 16)
+ * - `H` - Line height [mm] (default 0.6)
+ * - `U` - Pressurizing extrusion before the line [mm] (default 5)
+ * - `D` - Direction: 0 = line along X, 1 = along Y (default 0)
+ * - `X`, `Y` - Start position override [mm] (default: front-left bed corner)
+ * - `C` - Adaptive placement: 1 = on, 0 = off (default 1)
+ * - `M` - Margin kept from the print area in adaptive mode [mm] (default 10)
+ * - `B` - Max line cross-section [mm^2] (default 5); purge length is reduced to fit
+ */
+void PrusaGcodeSuite::G751() {
+    GCodeParser2 p;
+    if (!p.parse_marlin_command()) {
+        return;
+    }
+
+    squiggly_purge::Params params;
+    params.purge_length = p.option<float>('L').value_or(params.purge_length);
+    params.flowrate = p.option<float>('Q').value_or(params.flowrate);
+    params.amplitude = p.option<float>('A').value_or(params.amplitude);
+    params.wavelength = p.option<float>('W').value_or(params.wavelength);
+    params.periods = p.option<int>('P').value_or(params.periods);
+    params.steps_per_period = p.option<int>('S').value_or(params.steps_per_period);
+    params.line_height = p.option<float>('H').value_or(params.line_height);
+    params.unretract = p.option<float>('U').value_or(params.unretract);
+    params.along_y = p.option<bool>('D').value_or(params.along_y);
+    params.adaptive = p.option<bool>('C').value_or(params.adaptive);
+    params.margin = p.option<float>('M').value_or(params.margin);
+    params.max_cross_section = p.option<float>('B').value_or(params.max_cross_section);
+
+    if (axes_need_homing()) {
+        SERIAL_ERROR_MSG("G751: axes not homed");
+        return;
+    }
+    if (thermalManager.tooColdToExtrude(active_extruder)) {
+        SERIAL_ERROR_MSG("G751: hotend too cold to extrude");
+        return;
+    }
+
+    const auto geometry = squiggly_purge::compute_geometry(params);
+    if (!geometry) {
+        report_error(geometry.error());
+        return;
+    }
+    if (geometry->capped) {
+        SERIAL_ECHO_MSG("G751: purge length reduced to fit the B cross-section limit");
+    }
+
+    const squiggly_purge::Rect bed_rect { X_MIN_POS, Y_MIN_POS, X_MAX_POS, Y_MAX_POS };
+
+    std::optional<squiggly_purge::Rect> print_rect;
+    const auto area = PrintArea::get_bounding_rect();
+    if (area.a.x != std::numeric_limits<float>::lowest()) { // M555 was received
+        print_rect = squiggly_purge::Rect { area.a.x, area.a.y, area.b.x, area.b.y };
+    }
+
+    const auto start = squiggly_purge::compute_placement(params, bed_rect, print_rect,
+        p.option<float>('X'), p.option<float>('Y'));
+    if (!start) {
+        report_error(start.error());
+        return;
+    }
+
+    xyze_pos_t target = current_position;
+    const auto move_to = [&target](feedRate_t feedrate) {
+        prepare_move_to(target, feedrate, {});
+    };
+
+    if (target.z < safe_z) {
+        target.z = safe_z;
+        move_to(z_feedrate);
+    }
+
+    target.x = start->x;
+    target.y = start->y;
+    move_to(travel_feedrate);
+
+    target.z = squish * params.line_height;
+    move_to(z_feedrate);
+
+    target.e += params.unretract;
+    move_to(pressurize_feedrate);
+
+    const int segments = squiggly_purge::segment_count(params);
+    const float length = squiggly_purge::path_length(params);
+    squiggly_purge::PathPoint prev = squiggly_purge::path_point(params, 0);
+    for (int i = 1; i <= segments; i++) {
+        const auto pt = squiggly_purge::path_point(params, i);
+        const float segment = std::hypot(pt.along - prev.along, pt.across - prev.across);
+        if (params.along_y) {
+            target.x = start->x + pt.across;
+            target.y = start->y + pt.along;
+        } else {
+            target.x = start->x + pt.along;
+            target.y = start->y + pt.across;
+        }
+        target.e += segment / length * geometry->purge_length;
+        move_to(geometry->feedrate);
+        prev = pt;
+    }
+
+    target.e -= retract;
+    move_to(retract_feedrate);
+
+    target.z += end_hop;
+    move_to(z_feedrate);
+
+    target.x += sidestep;
+    target.y += sidestep;
+    move_to(travel_feedrate);
+
+    planner.synchronize();
+}
+
+/** @}*/
