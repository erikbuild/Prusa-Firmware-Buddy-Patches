+/// @file
+// ABOUTME: Pure geometry and extrusion math for the G751 squiggly purge line.
+// ABOUTME: No Marlin or hardware dependencies; unit-tested on host.
+#pragma once
+
+#include <expected>
+#include <optional>
+
+namespace squiggly_purge {
+
+inline constexpr float filament_diameter = 1.75f;
+
+struct Params {
+    float purge_length = 100.f; ///< mm of filament to purge
+    float flowrate = 10.f; ///< volumetric flow along the line, mm^3/s
+    float amplitude = 5.f; ///< squiggle peak offset, mm
+    float wavelength = 5.f; ///< length of one period along the line, mm
+    int periods = 10;
+    int steps_per_period = 16; ///< linear segments approximating one period
+    float line_height = 0.6f; ///< mm
+    float unretract = 5.f; ///< pressurizing extrusion before the line, mm
+    bool along_y = false; ///< false: line runs along X, squiggle offsets in +Y; true: swapped
+    bool adaptive = true; ///< slide the line toward the print area when known
+    float margin = 10.f; ///< distance kept from the print area in adaptive mode, mm
+    float max_cross_section = 5.f; ///< line cross-section limit, mm^2
+};
+
+enum class Error {
+    degenerate_params, ///< a parameter is zero or negative where that makes no sense
+    line_too_thin, ///< computed line is too thin to stick to the bed
+    does_not_fit, ///< the line (incl. amplitude envelope) cannot fit on the bed
+};
+
+/// Number of linear segments the line consists of
+int segment_count(const Params &p);
+
+struct PathPoint {
+    float along; ///< distance from the line start along the line direction, mm
+    float across; ///< squiggle offset perpendicular to the line, 0..amplitude, mm
+};
+
+/// Path vertex i, for i in 0..segment_count(); vertex 0 is {0, 0}
+PathPoint path_point(const Params &p, int i);
+
+/// Sum of all segment lengths, mm
+float path_length(const Params &p);
+
+struct Geometry {
+    float line_width; ///< mm
+    float feedrate; ///< mm/s
+    float purge_length; ///< mm of filament, reduced from Params if capped
+    bool capped; ///< purge_length was reduced to honor max_cross_section
+};
+
+std::expected<Geometry, Error> compute_geometry(const Params &p);
+
+struct Rect {
+    float x_min, y_min, x_max, y_max;
+};
+
+struct Start {
+    float x, y;
+};
+
+/// Absolute start position of the line.
+/// print_area: first-layer bounding box (from M555), nullopt when not known.
+/// override_x/y: caller-forced base position; adaptive sliding and bed clamping still apply.
+std::expected<Start, Error> compute_placement(const Params &p, const Rect &bed,
+    const std::optional<Rect> &print_area,
+    std::optional<float> override_x, std::optional<float> override_y);
+
+} // namespace squiggly_purge
