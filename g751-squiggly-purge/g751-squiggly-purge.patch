+/// @file
+// ABOUTME: Pure geometry and extrusion math for the G751 squiggly purge line.
+// ABOUTME: Cosine path, flow-derived line width/feedrate, adaptive placement.
+#include "squiggly_purge.hpp"
+
+#include <algorithm>
+#include <cmath>
+#include <numbers>
+
+namespace squiggly_purge {
+
+namespace {
+    constexpr float filament_area = std::numbers::pi_v<float> * (filament_diameter / 2) * (filament_diameter / 2);
+    constexpr float cap_fill = 0.98f; ///< stay slightly under max_cross_section after capping
+    constexpr float min_width_to_height = 2.f; ///< thinner lines than this do not stick to the bed
+
+    bool params_valid(const Params &p) {
+        return p.periods >= 1 && p.steps_per_period >= 1
+            && p.purge_length > 0 && p.flowrate > 0
+            && p.amplitude >= 0 && p.wavelength > 0
+            && p.line_height > 0 && p.margin >= 0
+            && p.max_cross_section > 0;
+    }
+} // namespace
+
+int segment_count(const Params &p) {
+    return p.periods * p.steps_per_period;
+}
+
+PathPoint path_point(const Params &p, int i) {
+    const float phase = float(i) / float(p.steps_per_period) * 2 * std::numbers::pi_v<float>;
+    return {
+        .along = float(i) * p.wavelength / float(p.steps_per_period),
+        .across = p.amplitude * (0.5f - 0.5f * std::cos(phase)),
+    };
+}
+
+float path_length(const Params &p) {
+    float length = 0;
+    PathPoint prev = path_point(p, 0);
+    for (int i = 1; i <= segment_count(p); i++) {
+        const PathPoint pt = path_point(p, i);
+        length += std::hypot(pt.along - prev.along, pt.across - prev.across);
+        prev = pt;
+    }
+    return length;
+}
+
+std::expected<Geometry, Error> compute_geometry(const Params &p) {
+    if (!params_valid(p)) {
+        return std::unexpected(Error::degenerate_params);
+    }
+
+    const float length = path_length(p);
+    Geometry g {
+        .line_width = p.purge_length * filament_area / (p.line_height * length),
+        .feedrate = 0,
+        .purge_length = p.purge_length,
+        .capped = false,
+    };
+
+    if (p.line_height * g.line_width > p.max_cross_section) {
+        g.capped = true;
+        g.purge_length = cap_fill * p.max_cross_section * length / filament_area;
+        g.line_width = g.purge_length * filament_area / (p.line_height * length);
+    }
+
+    // the Klipper macro aborts at height/width >= 0.5, i.e. width <= 2 * height
+    if (g.line_width <= min_width_to_height * p.line_height) {
+        return std::unexpected(Error::line_too_thin);
+    }
+
+    g.feedrate = p.flowrate / (p.line_height * g.line_width);
+    return g;
+}
+
+std::expected<Start, Error> compute_placement(const Params &p, const Rect &bed,
+    const std::optional<Rect> &print_area,
+    std::optional<float> override_x, std::optional<float> override_y) {
+    if (!params_valid(p)) {
+        return std::unexpected(Error::degenerate_params);
+    }
+
+    const float line_length = float(p.periods) * p.wavelength;
+
+    // Direction-agnostic frame: "along" the line direction, "across" perpendicular to it
+    const float bed_along_min = p.along_y ? bed.y_min : bed.x_min;
+    const float bed_along_max = p.along_y ? bed.y_max : bed.x_max;
+    const float bed_across_min = p.along_y ? bed.x_min : bed.y_min;
+    const float bed_across_max = p.along_y ? bed.x_max : bed.y_max;
+
+    if (line_length > bed_along_max - bed_along_min || p.amplitude > bed_across_max - bed_across_min) {
+        return std::unexpected(Error::does_not_fit);
+    }
+
+    const std::optional<float> &override_along = p.along_y ? override_y : override_x;
+    const std::optional<float> &override_across = p.along_y ? override_x : override_y;
+
+    float along = override_along.value_or(bed_along_min + 5.f);
+    float across = override_across.value_or(bed_across_min + 3.5f);
+
+    if (p.adaptive && print_area) {
+        const float area_along_min = p.along_y ? print_area->y_min : print_area->x_min;
+        const float area_along_max = p.along_y ? print_area->y_max : print_area->x_max;
+        along = std::clamp(along, area_along_min - p.margin, area_along_max + p.margin);
+    }
+
+    along = std::clamp(along, bed_along_min, bed_along_max - line_length);
+    across = std::clamp(across, bed_across_min, bed_across_max - p.amplitude);
+
+    return p.along_y ? Start { .x = across, .y = along } : Start { .x = along, .y = across };
+}
+
+} // namespace squiggly_purge
