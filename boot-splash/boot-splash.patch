diff --git a/tests/unit/common/memory_byte_reader_test.cpp b/tests/unit/common/memory_byte_reader_test.cpp
new file mode 100644
index 00000000..3633f93e
--- /dev/null
+++ b/tests/unit/common/memory_byte_reader_test.cpp
@@ -0,0 +1,28 @@
+#include <catch2/catch_test_macros.hpp>
+#include <cstdint>
+#include <memory_byte_reader.hpp>
+
+TEST_CASE("MemoryByteReader reads sequentially in chunks", "[memory_byte_reader]") {
+    const uint8_t src[] = { 10, 20, 30, 40, 50 };
+    MemoryByteReader reader(src, sizeof(src));
+
+    uint8_t buf[2] = {};
+    auto a = reader.read(std::span<uint8_t>(buf, 2));
+    REQUIRE(a.size() == 2);
+    REQUIRE(buf[0] == 10);
+    REQUIRE(buf[1] == 20);
+
+    auto b = reader.read(std::span<uint8_t>(buf, 2));
+    REQUIRE(b.size() == 2);
+    REQUIRE(buf[0] == 30);
+    REQUIRE(buf[1] == 40);
+
+    // Final partial read: only 1 byte left
+    auto c = reader.read(std::span<uint8_t>(buf, 2));
+    REQUIRE(c.size() == 1);
+    REQUIRE(buf[0] == 50);
+
+    // At end: empty span
+    auto d = reader.read(std::span<uint8_t>(buf, 2));
+    REQUIRE(d.size() == 0);
+}
diff --git a/utils/qoi_to_cpp.py b/utils/qoi_to_cpp.py
new file mode 100755
index 00000000..f394b0c4
--- /dev/null
+++ b/utils/qoi_to_cpp.py
@@ -0,0 +1,37 @@
+#!/usr/bin/env python3
+# ABOUTME: Encodes a single PNG to QOI and emits a C++ header with the bytes as
+# ABOUTME: an inline constexpr array plus its width/height, for compile-time use.
+from argparse import ArgumentParser
+from pathlib import Path
+from PIL import Image
+import numpy
+import qoi
+
+
+def main():
+    parser = ArgumentParser()
+    parser.add_argument("input", type=Path, help="Path to the source PNG")
+    parser.add_argument("output", type=Path, help="Path to the generated .hpp")
+    parser.add_argument("--namespace", default="splash_pony")
+    args = parser.parse_args()
+
+    with Image.open(args.input).convert("RGBA") as png:
+        width, height = png.width, png.height
+        data = qoi.encode(numpy.array(png))
+
+    args.output.parent.mkdir(parents=True, exist_ok=True)
+    with open(args.output, "w") as f:
+        f.write("#pragma once\n#include <cstddef>\n#include <cstdint>\n\n")
+        f.write(f"namespace {args.namespace} {{\n")
+        f.write(f"inline constexpr uint16_t width = {width};\n")
+        f.write(f"inline constexpr uint16_t height = {height};\n")
+        f.write("inline constexpr uint8_t qoi_data[] = {\n")
+        for i in range(0, len(data), 16):
+            f.write("    " + ",".join(str(b) for b in data[i:i + 16]) + ",\n")
+        f.write("};\n")
+        f.write("inline constexpr size_t qoi_size = sizeof(qoi_data);\n")
+        f.write(f"}} // namespace {args.namespace}\n")
+
+
+if __name__ == "__main__":
+    main()
