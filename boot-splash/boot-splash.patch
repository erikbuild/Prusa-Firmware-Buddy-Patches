diff --git a/src/common/memory_byte_reader.hpp b/src/common/memory_byte_reader.hpp
new file mode 100644
index 00000000..9ce58454
--- /dev/null
+++ b/src/common/memory_byte_reader.hpp
@@ -0,0 +1,32 @@
+/// @file
+// ABOUTME: AbstractByteReader that reads sequentially from an in-memory buffer.
+// ABOUTME: Used to decode a compiled-in QOI image without the flash resource file.
+#pragma once
+
+#include "abstract_byte_reader.hpp"
+#include <algorithm>
+#include <cstring>
+
+class MemoryByteReader final : public AbstractByteReader {
+public:
+    MemoryByteReader(const uint8_t *data, size_t size)
+        : data_(data)
+        , size_(size)
+        , pos_(0) {}
+
+    // Overriding read(span<byte>) hides the base read(span<uint8_t>) convenience
+    // overload; re-expose it so callers (and the unit test) can use either.
+    using AbstractByteReader::read;
+
+    std::span<std::byte> read(std::span<std::byte> buffer) final {
+        const size_t n = std::min(buffer.size(), size_ - pos_);
+        std::memcpy(buffer.data(), data_ + pos_, n);
+        pos_ += n;
+        return { buffer.data(), n };
+    }
+
+private:
+    const uint8_t *data_;
+    size_t size_;
+    size_t pos_;
+};
